# Application Configuration
APP_ENV=development
APP_NAME="AI-Powered Job Recommendation Assistant"
HOST=0.0.0.0
PORT=8000

# Database Configuration
# Use postgresql+asyncpg for async SQLAlchemy operations
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/job_recommendation_db

# Security & JWT Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Qdrant Vector Database
# Local setup (use docker-compose): http://localhost:6333
# Cloud setup: https://xxxxxx.gcp.qdrant.io:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# Embedding Configuration
EMBEDDINGS_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
